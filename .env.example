# ── Required ──────────────────────────────────────────────────────────────
# MongoDB Atlas connection string with READ/WRITE access. Include the database
# name in the path (use /jaxstudio). URL-encode special chars in the password.
DATABASE_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/jaxstudio?retryWrites=true&w=majority

# Long random string Payload uses to sign tokens. Any 32+ char random value.
PAYLOAD_SECRET=replace-with-a-long-random-string

# ── Email (SendGrid) ────────────────────────────────────────────────────────
# Contact form sends an owner notification + customer auto-reply. The
# jaxstudio.ink domain is already verified in SendGrid.
SENDGRID_API_KEY=
SENDER_EMAIL=hello@jaxstudio.ink
SENDER_NAME=Jax Studio
OWNER_EMAIL=jaxstudio.ink@gmail.com

# ── Optional ──────────────────────────────────────────────────────────────
# Vercel Blob token — needed once you upload media through the deployed /admin.
# Create a Blob store in the Vercel dashboard to get it. When unset, media is
# stored on local disk in dev.
# BLOB_READ_WRITE_TOKEN=
